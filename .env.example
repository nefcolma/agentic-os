# ─────────────────────────────────────────────────────────────────────
# MyBrain Agentic OS Dashboard — configuración local
# Copia este archivo a .env y ajusta los valores si hace falta.
#
# IMPORTANTE — credenciales:
#   Las credenciales de Odoo (ODOO_URL, ODOO_DB, ODOO_USERNAME, ODOO_API_KEY)
#   y de GHL (GHL_API_TOKEN, GHL_LOCATION_ID) NO van en este archivo.
#   El backend las hereda del entorno del shell (~/.zshenv), igual que cron.
#   Nunca se envían al frontend ni se escriben en logs.
# ─────────────────────────────────────────────────────────────────────

# Puerto del backend (Express). El frontend (Vite) hace proxy de /api hacia él.
# Se llama BACKEND_PORT (y no PORT) a propósito: herramientas de desarrollo
# suelen inyectar PORT para el dev server del frontend y no debe interferir.
BACKEND_PORT=8790

# Host del backend. Solo se aceptan direcciones loopback
# (127.0.0.1, localhost, ::1). El servidor se niega a arrancar con
# cualquier otro valor — nunca 0.0.0.0.
HOST=127.0.0.1

# Vault POR DEFECTO solamente. Cada usuario conecta el suyo desde la UI
# (Settings → Connect a different vault), y esa elección se guarda en
# backend/data/settings.json y tiene precedencia sobre esta variable.
# Solo se usa como fallback cuando aún no se ha conectado ninguno.
MYBRAIN_VAULT_PATH=~/Documents/MyBrain

# Binario de Claude Code CLI. Si no está en el PATH del proceso,
# usa la ruta absoluta (ej. /Users/josh/.local/bin/claude).
CLAUDE_BIN=claude

# Ruta al script read-only de Odoo. Por defecto se deriva del vault:
#   $MYBRAIN_VAULT_PATH/.claude/skills/odoo-sync/odoo_sync.py
# ODOO_SCRIPT_PATH=

# Rutas de prompts (por defecto derivadas del vault):
#   $MYBRAIN_VAULT_PATH/.claude/prompts/weekly-digest.txt
#   $MYBRAIN_VAULT_PATH/.claude/prompts/inbox-classify.txt  (aún no existe → "not configured")
# WEEKLY_DIGEST_PROMPT_PATH=
# INBOX_CLASSIFY_PROMPT_PATH=

# ─────────────────────────────────────────────────────────────────────
# Acceso remoto vía Cloudflare Tunnel + Access (OPCIONAL)
#
# Déjalo todo vacío para el modo local puro (recomendado por defecto).
# Si lo activas: el tráfico que llegue por el túnel EXIGE un JWT de Access
# válido (fail-closed). Declarar el host aquí NO concede acceso por sí solo.
# ─────────────────────────────────────────────────────────────────────

# Hostname de tu túnel. El tráfico que llega aquí se trata como REMOTO.
# TRUSTED_HOSTS=brain.colma.com

# Origen(es) del navegador permitidos para peticiones que cambian estado.
# TRUSTED_ORIGINS=https://brain.colma.com

# Tu team domain de Cloudflare Zero Trust.
# ACCESS_TEAM_DOMAIN=tuequipo.cloudflareaccess.com

# El "Application Audience (AUD) Tag" de la aplicación en Access.
# ACCESS_AUD=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Emails con permiso de ESCRITURA. Cualquier otro usuario autenticado por
# Access entra en modo SOLO LECTURA.
# ADMIN_EMAILS=neftali@colma.com

# Timeouts de procesos hijos (milisegundos)
CLAUDE_RUN_TIMEOUT_MS=900000
ODOO_TIMEOUT_MS=60000

# Tamaño máximo retenido del log de una ejecución (bytes)
MAX_RUN_LOG_BYTES=1048576
